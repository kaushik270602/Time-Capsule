# ===========================================
# TimeLock - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# --- PostgreSQL ---
POSTGRES_USER=timelock
POSTGRES_PASSWORD=timelock
POSTGRES_DB=timelock
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend ---
BACKEND_PORT=8000
DEBUG=false
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- AWS S3 (Media Storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=timelock-media

# --- OpenAI (AI Analysis & Transcription) ---
OPENAI_API_KEY=

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
